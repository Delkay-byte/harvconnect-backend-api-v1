###############################################################################
# Application
###############################################################################

NODE_ENV=development
PORT=5000

###############################################################################
# Database
###############################################################################

DATABASE_URL="postgresql://username:password@localhost:5432/harvconnect?schema=public"

###############################################################################
# Authentication
###############################################################################

JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

###############################################################################
# Email (Resend)
###############################################################################

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example:
# HarvConnect <onboarding@resend.dev>  (development)
# HarvConnect <noreply@yourdomain.com> (production)

RESEND_FROM_EMAIL="HarvConnect <onboarding@resend.dev>"

###############################################################################
# Frontend
###############################################################################

FRONTEND_URL=http://localhost:3000

###############################################################################
# Demo / Development
###############################################################################

HACKATHON_DEMO_MODE=false

###############################################################################
# Logging
###############################################################################

LOG_LEVEL=info