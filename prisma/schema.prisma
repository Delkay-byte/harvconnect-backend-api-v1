generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  fullName            String
  email               String            @unique
  phone               String            @unique
  password            String
  role                Role
  isActive            Boolean           @default(true)
  isVerified          Boolean           @default(false)
  emailVerifiedAt     DateTime?
  lastLogin           DateTime?
  lastPasswordResetAt DateTime?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  authTokens          AuthToken[]
  buyerProfile        BuyerProfile?
  farmerProfile       FarmerProfile?
  ordersAsBuyer       Order[]           @relation("BuyerOrders")
  ordersAsFarmer      Order[]           @relation("FarmerOrders")
  ordersAsTransporter Order[]           @relation("TransporterOrders")
  products            Product[]
  reviewsAsBuyer      Review[]          @relation("BuyerReviews")
  reviewsAsFarmer     Review[]          @relation("FarmerReviews")
  transportProfile    TransportProfile?
}

model FarmerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  farmName  String?
  bio       String?
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model BuyerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  deliveryAddress String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model TransportProfile {
  id             String                   @id @default(uuid())
  userId         String                   @unique
  vehicleType    VehicleType
  capacity       Float
  isAvailable    Boolean                  @default(true)
  currentAddress String?
  currentRegion  String?
  currentLat     Float?
  currentLng     Float?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  /// Unsupported("geometry")
  location       Unsupported("geometry")?
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isAvailable])
  @@index([currentLat, currentLng])
  @@index([location], type: Gist)
}

model Product {
  id          String    @id @default(uuid())
  farmerId    String
  name        String
  category    Commodity
  quantity    Decimal
  price       Decimal
  unit        String
  description String?
  imageUrl    String?
  harvestDate DateTime?
  available   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
  farmer      User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([available])
  @@index([farmerId])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  buyerId         String
  farmerId        String
  transporterId   String?
  productId       String
  quantity        Int
  totalPrice      Float
  pickupAddress   String
  deliveryAddress String
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  farmer          User        @relation("FarmerOrders", fields: [farmerId], references: [id])
  product         Product     @relation(fields: [productId], references: [id])
  transporter     User?       @relation("TransporterOrders", fields: [transporterId], references: [id])

  @@index([buyerId])
  @@index([farmerId])
  @@index([transporterId])
  @@index([productId])
  @@index([status])
}

model AuthToken {
  id        String    @id @default(uuid())
  userId    String
  type      TokenType
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([userId, type])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  buyerId   String
  farmerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id], onDelete: Cascade)
  farmer    User     @relation("FarmerReviews", fields: [farmerId], references: [id], onDelete: Cascade)

  @@unique([buyerId, farmerId])
  @@index([farmerId])
  @@index([buyerId])
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum Role {
  FARMER
  BUYER
  TRANSPORT
  ADMIN
}

enum VehicleType {
  MOTORBIKE
  TRICYCLE
  PICKUP
  MINI_TRUCK
  TRUCK
  OTHER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  READY_FOR_TRANSPORT
  PENDING_DISPATCH
  IN_TRANSIT
  DELIVERED
  REJECTED
  CANCELLED
}

enum Commodity {
  TOMATO_LOCAL
  TOMATO_HYBRID
  PEPPER
  OKRA
  GARDEN_EGGS
  CABBAGE
  LETTUCE
  CUCUMBER
  ONION
}

enum TokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}
