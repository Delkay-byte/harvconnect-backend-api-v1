generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  fullName         String
  email            String            @unique
  phone            String            @unique
  password         String
  role             Role
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isVerified       Boolean           @default(false)
  lastLogin        DateTime?
  buyerProfile     BuyerProfile?
  farmerProfile    FarmerProfile?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  ordersAsBuyer       Order[] @relation("BuyerOrders")
  ordersAsFarmer      Order[] @relation("FarmerOrders")
  ordersAsTransporter Order[] @relation("TransporterOrders")
  products         Product[]
  transportProfile TransportProfile?
}

model FarmerProfile {
  id        String   @id @default(uuid())
  farmName  String?
  bio       String?
  latitude  Float?
  longitude Float?
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  address   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
}

model BuyerProfile {
  id              String   @id @default(uuid())
  deliveryAddress String?
  latitude        Float?
  longitude       Float?
  userId          String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TransportProfile {
  id             String      @id @default(uuid())
  vehicleType    VehicleType
  capacity       Float
  latitude       Float?
  longitude      Float?
  currentAddress String?
  available      Boolean     @default(true)
  userId         String      @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([available])
}

model Product {
  id          String    @id @default(uuid())
  name        String
  quantity    Decimal
  price       Decimal
  unit        String
  imageUrl    String?
  available   Boolean   @default(true)
  harvestDate DateTime?
  description String?
  farmerId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    Commodity
  orders      Order[]
  farmer      User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([available])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique // A short, readable ID like "ORD-8F2A"
  
  // Relationships
  buyerId         String
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  
  farmerId        String
  farmer          User        @relation("FarmerOrders", fields: [farmerId], references: [id])
  
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  
  // Transport Relationship (Optional initially, populated in Phase 4)
  transporterId   String?
  transporter     User?       @relation("TransporterOrders", fields: [transporterId], references: [id])

  // Transaction Details
  quantity        Int
  totalPrice      Float       // quantity * product.price at the time of order
  status          OrderStatus @default(PENDING)
  
  // Location Snapshots (in case profiles change later, the order keeps the historical addresses)
  pickupAddress   String
  deliveryAddress String

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  FARMER
  BUYER
  TRANSPORT
}

enum VehicleType {
  MOTORBIKE
  TRICYCLE
  PICKUP
  MINI_TRUCK
  TRUCK
  OTHER
}

enum OrderStatus {
  PENDING              // Buyer placed order, waiting for Farmer
  ACCEPTED             // Farmer confirmed they have the stock
  REJECTED             // Farmer declined (e.g., stock ruined)
  READY_FOR_TRANSPORT  // Farmer packed it, waiting for driver assignment (Phase 4 trigger)
  IN_TRANSIT           // Driver picked it up
  DELIVERED            // Buyer received it
  CANCELLED            // Cancelled before processing
}

enum Commodity {
  TOMATO_LOCAL
  TOMATO_HYBRID
  PEPPER
  OKRA
  GARDEN_EGGS
  CABBAGE
  LETTUCE
  CUCUMBER
  ONION
}

